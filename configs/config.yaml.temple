app:
  name: dipole
  env: local

log:
  level: info
  format: console
  development: true
  file_enabled: true
  file_path: logs/dipole.log
  file_rotate_daily: true

server:
  host: 0.0.0.0
  port: 8080

tls:
  enabled: true
  cert_file: certs/local/dipole-local.pem
  key_file: certs/local/dipole-local-key.pem

auth:
  token_ttl_hours: 168
  jwt_secret: dipole-dev-jwt-secret-change-me
  jwt_issuer: dipole

mysql:
  host: 127.0.0.1
  port: 3306
  user: dipole
  password: dipole123
  dbname: dipole

redis:
  host: 127.0.0.1
  port: 6379
  password: ""
  db: 0

kafka:
  enabled: true
  brokers:
    - 127.0.0.1:9092
  client_id: dipole
  topic_prefix: dipole
  dial_timeout_seconds: 5
  write_timeout_seconds: 5
  consume_retry_max_attempts: 3
  consume_retry_backoff_ms: 500

storage:
  enabled: true
  provider: minio
  endpoint: 127.0.0.1:9000
  access_key: dipoleminio
  secret_key: dipoleminiopass
  use_ssl: false
  bucket: dipole-files
  public_base_url: http://127.0.0.1:9000/dipole-files
  file_max_size_mb: 50

rate_limit:
  enabled: true
  login_limit: 10
  login_window_seconds: 300
  message_limit: 120
  message_window_seconds: 60
  file_upload_limit: 10
  file_upload_window_seconds: 300

presence:
  enabled: true
  node_id: ""
  ttl_seconds: 120

ai:
  enabled: false
  provider: openai
  model: gpt-4o-mini
  api_key: ""
  base_url: ""
  timeout_seconds: 30
  max_context_messages: 12
  assistant_uuid: UAI000000000000000001
  assistant_nickname: Dipole AI
  assistant_telephone: "19900000000"
  assistant_email: ai@dipole.local
  assistant_avatar: https://cube.elemecdn.com/0/88/03b0d39583f48206768a7534e55bcpng.png
  system_prompt: >
    You are Dipole AI, a concise and helpful instant messaging assistant.
    Use the conversation context to answer naturally.
    If the user sends a file, acknowledge the file metadata you can see.
    Keep answers short unless the user asks for depth.
